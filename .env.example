# ─── Kafka (Local Docker) ────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BOOTSTRAP_SERVERS_LOCAL=localhost:9092
KAFKA_TOPIC_HACKERNEWS=hackernews-posts
KAFKA_TOPIC_GITHUB=github-events
KAFKA_TOPIC_YOUTUBE=youtube-videos

# ─── Cloudflare R2 ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=data-lake

# ─── Neon PostgreSQL ─────────────────────────────────────────
NEON_CONNECTION_STRING=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/analytics_db
NEON_HOST=ep-xxx.us-east-2.aws.neon.tech
NEON_USER=user
NEON_PASSWORD=password
NEON_DBNAME=analytics_db

# ─── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=engagement-predictor

# ─── API Keys ─────────────────────────────────────────────────
# Hacker News needs no API key
GITHUB_TOKEN=
YOUTUBE_API_KEY=
